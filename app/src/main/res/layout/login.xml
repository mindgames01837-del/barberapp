<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">
    <!--  ═══════════════════════════════════════  -->
    <!--               HERO HEADER                -->
    <!--  ═══════════════════════════════════════  -->
    <FrameLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="240dp">
        <!--  Dark background base  -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1A1A2E" />
        <!--  Barber hero image with dark overlay  -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/barberowner"
            android:alpha="0.35" />
        <!--  Dark gradient overlay  -->
        <!--  Brand Row: Logo + Name  -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_hero_gradient" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_extrabold"
                    android:letterSpacing="0.12"
                    android:text="ROLL'N CUTS"
                    android:textColor="#F6C904"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="PREMIUM HAIR FASHION CUTS"
                    android:textColor="#888888"
                    android:textSize="9sp" />
            </LinearLayout>
        </LinearLayout>
        <!--  Hero Tagline  -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="44dp"
            android:layout_marginStart="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.05"
                android:text="Welcome"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="-0.02"
                android:text="Back."
                android:textColor="#42A5F5"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sign in to manage your bookings &amp; style"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

    </FrameLayout>
    <!--  ═══════════════════════════════════════  -->
    <!--               FORM CARD                  -->
    <!--  ═══════════════════════════════════════  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_marginTop="-20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_login_container"
            android:orientation="vertical"
            android:paddingTop="14dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">
            <!--  Drag handle  -->
            <View
                android:layout_width="36dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="#E0E0E0" />
            <!--  Form title  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="-0.02"
                android:text="Login"
                android:textColor="#0A0A0A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="22dp"
                android:text="Enter your credentials to continue"
                android:textColor="#888888"
                android:textSize="11sp" />
            <!--  ─── Email Field ───  -->
            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.06"
                android:text="EMAIL ADDRESS"
                android:textColor="#444444"
                android:textSize="10sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="14dp">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_field_active_blue"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="10dp"
                    android:hint="you@email.com"
                    android:inputType="textEmailAddress"
                    android:paddingStart="38dp"
                    android:paddingEnd="14dp"
                    android:textColor="#0A0A0A"
                    android:textColorHint="#C8C8C8"
                    android:textSize="13sp" />
            </FrameLayout>
            <!--  ─── Password Field ───  -->
            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/inter_bold"
                android:letterSpacing="0.06"
                android:text="PASSWORD"
                android:textColor="#444444"
                android:textSize="10sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="44dp">

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_field_default"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawablePadding="10dp"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="38dp"
                    android:paddingEnd="40dp"
                    android:textColor="#0A0A0A"
                    android:textColorHint="#C8C8C8"
                    android:textSize="13sp" />
                <!--  Eye toggle  -->
                <ImageView
                    android:id="@+id/ivEyeToggle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_eye" />
            </FrameLayout>
            <!--  Forgot Password  -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="18dp"
                android:fontFamily="@font/inter_semibold"
                android:text="Forgot Password?"
                android:textColor="#C09E15"
                android:textSize="11sp" />
            <!--  ─── Login Button ───  -->
            <!--  ─── Divider ───  -->

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_btn_add_circle"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="8dp"
                android:fontFamily="@font/inter_bold"
                android:gravity="center"
                android:paddingEnd="10dp"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#EBEBEB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:text="Or login with"
                    android:textColor="#C8C8C8"
                    android:textSize="10sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#EBEBEB" />
            </LinearLayout>
            <!--  ─── Social Buttons ───  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                <!--  Facebook  -->
                <Button
                    android:id="@+id/btnFacebook"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_facebook"
                    android:drawableStart="@drawable/ic_facebook"
                    android:drawablePadding="6dp"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Facebook"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />
                <!--  Google  -->
                <Button
                    android:id="@+id/btnGoogle"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_social"
                    android:drawableStart="@drawable/ic_google"
                    android:drawablePadding="6dp"
                    android:fontFamily="@font/inter_semibold"
                    android:text="Google"
                    android:textAllCaps="false"
                    android:textColor="#0A0A0A"
                    android:textSize="10sp" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />
                <!--  GitHub  -->
                <Button
                    android:id="@+id/btnGithub"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_github"
                    android:drawableStart="@drawable/ic_github"
                    android:drawablePadding="6dp"
                    android:fontFamily="@font/inter_semibold"
                    android:text="GitHub"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>
            <!--  ─── Sign Up Link ───  -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textColor="#888888"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="Sign Up"
                    android:textColor="#1565C0"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>